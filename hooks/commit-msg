#!/usr/bin/env node
/*
 * SDD 命令层硬门禁 / commit-msg git hook —— 零 LLM，强制 commit message 走 Conventional Commits。
 *
 * 与 Stop hook（gate_reminder.js，判断层、靠 LLM 执行）不同，这是【命令层】：
 * git 在每次 commit 写完 message 后必跑本脚本，格式不合规直接 **拒绝提交**（退出码非 0）。
 * 即使绕过 Claude 手敲 git commit 也挡得住——这就是 README 里说"尚未内置"的最强一环。
 *
 * 规范（Conventional Commits）：
 *     <type>[optional scope][!]: <subject>
 *
 *     [optional body]
 *     [optional footer(s)]
 *
 *   type      必填，取值：feat fix docs style refactor perf test build ci chore revert
 *   scope     可选，括号内小写标识，如 (auth) (api)
 *   !         可选，表示破坏性变更（也可在 footer 写 BREAKING CHANGE:）
 *   subject   必填，冒号后一个空格 + 简述；建议祈使句、不以句号结尾
 *
 *   例：
 *     feat(auth): 增加手机号登录
 *     fix: 修正空购物车结算崩溃
 *     refactor(api)!: 重命名 user 字段（破坏性）
 *
 * 安全设计（fail-open，绝不无故卡住正常提交）：
 * - 自动放行：merge / revert / fixup! / squash! / amend-autosquash 等特殊提交。
 * - 自动放行：空消息或仅注释（git 自身会处理）。
 * - 脚本自身异常一律放行——hook 出 bug 不能困住用户。
 * - 只在「格式确实不合规」时拒绝，并打印清晰的修正提示。
 *
 * 安装：本文件需放到项目 `.git/hooks/commit-msg` 且可执行（见 README「提交规范」一节）。需要 node 在 PATH 上。
 * 关闭：删除 `.git/hooks/commit-msg`，或 `git commit --no-verify`（单次跳过）。
 */
'use strict';

const fs = require('fs');

const TYPES = ['feat', 'fix', 'docs', 'style', 'refactor',
  'perf', 'test', 'build', 'ci', 'chore', 'revert'];

// <type>(scope)?!?: <subject>
const HEADER_RE = new RegExp(
  '^(' + TYPES.join('|') + ')' +
  '(\\([^()\\r\\n]+\\))?' +
  '(!)?' +
  ': (.+)$'
);

// 这些提交不校验（git 自动生成或特殊流程）
const SKIP_RE = /^(Merge |Revert |fixup! |squash! |amend! )/i;

const MAX_HEADER = 100; // 标题硬上限，给得很宽松；只挡明显失控的超长行

function allow() {
  process.exit(0);
}

function reject(firstLine) {
  const msg =
    '\n✗ SDD 提交门禁：commit message 不符合 Conventional Commits 规范。\n\n' +
    `  你的标题：${firstLine}\n\n` +
    '  应为：  <type>(<scope>)?: <subject>\n' +
    '  type ∈ ' + TYPES.join(' | ') + '\n\n' +
    '  例：\n' +
    '    feat(auth): 增加手机号登录\n' +
    '    fix: 修正空购物车结算崩溃\n' +
    '    refactor(api)!: 重命名 user 字段（破坏性变更）\n\n' +
    '  修正后重新提交；确需跳过一次：git commit --no-verify\n';
  process.stderr.write(msg);
  process.exit(1);
}

function main() {
  // git 把 commit message 文件路径作为第一个参数传入
  const msgPath = process.argv[2];
  if (!msgPath) allow();
  let content;
  try {
    content = fs.readFileSync(msgPath, 'utf8');
  } catch (e) {
    allow(); // 读不到文件 → 放行自保
  }

  // 取第一行非注释、非空内容作为标题
  let firstLine = '';
  for (const line of content.split(/\r?\n/)) {
    const s = line.trim();
    if (!s || s.startsWith('#')) continue;
    firstLine = line.replace(/\s+$/, '');
    break;
  }

  if (!firstLine) allow(); // 空消息：交给 git 自己处理
  if (SKIP_RE.test(firstLine)) allow(); // merge/revert/fixup 等：放行

  const m = HEADER_RE.exec(firstLine);
  if (!m || !m[4].trim()) reject(firstLine);
  if (firstLine.length > MAX_HEADER) {
    process.stderr.write(
      `\n✗ SDD 提交门禁：标题过长（${firstLine.length} > ${MAX_HEADER} 字符）。` +
      '请精简标题，细节放正文。\n'
    );
    process.exit(1);
  }

  allow();
}

try {
  main();
} catch (e) {
  // 任何意外一律放行：门禁脚本本身绝不能困住提交
  allow();
}
